#ETAPA 02
pl.Config.set_tbl_cols(-1)
print(df.null_count()) #Através do null_count é possível verificarmos a quantidade de valores nulos em cada coluna. 
print("Quantidade de Valores Nulos")
print(df["price"].null_count()) #Verificando apenas a coluna price

dfclear = df.filter(pl.col("price").is_not_null()) #Criando um novo dataframe mantendo todas as linhas mas removendo apenas as linhas que a coluna price tinha valores nulos. 
linhasclear, colunasclear = dfclear.shape
print(f"{linhasclear} de Linhas\n{colunasclear} de Colunas")

