import polars as pl #Importando a biblioteca Polars e renomeando ela de 'pl'.

df = pl.read_csv("winemag-data_first150k.csv") #Carregando o DataSet de vinhos utilizando o pl.read_csv

#DataFrame Resumido entre as 5 primeiras linhas e as 5 ultimas linhas.
print(df.head()) #Mostrando as 5 primeiras linhas do DataSet
print(df.tail()) #Mostrando as 5 ultimas linhas do DataSet

#Verificação de Colunas e Linhas do DataSet
linhas, colunas = df.shape #Atrelei os dois indice do df.shape como linhas (Número de linhas) e como colunas (Número de colunas).
print(f"{linhas} de Linhas\n{colunas} de Colunas") #Printa a quantidade de linhas e colunas, 
print(df.columns) #Mostra apenas o nome de todas as colunas.
print(df.schema) #Mostra o nome de todas as colunas e tipo de dados 

#Estatística Resumida de rápido e fácil acesso.
print(df.describe()) #Mostra uma estatística resumida dos dados das colunas. 

